#!/usr/bin/env node

import { Command } from 'commander';
import { runMigrations } from './lib/migrations';
import { loadConfig } from './lib/config';
import { CompanyService } from './lib/company-service';
import { JobService } from './lib/job-service';
import type { Company, Job } from './types';

// Initialize database
runMigrations();
const config = loadConfig();
const token = config.githubToken || process.env.GITHUB_TOKEN || undefined;
const companyService = new CompanyService(token);
const jobService = new JobService(token);

const program = new Command();

program
  .name('gogetajob')
  .description('AI Agent Job Market - find work on GitHub')
  .version('2.0.0');

// --- feed ---
program
  .command('feed')
  .description('Browse open job opportunities')
  .option('--lang <language>', 'filter by programming language')
  .option('--type <type>', 'filter by type: bug, feature, docs, test, other')
  .option('--limit <n>', 'max results', '20')
  .action((opts) => {
    const jobs = jobService.getJobs({
      lang: opts.lang,
      type: opts.type,
      limit: parseInt(opts.limit),
    });

    if (jobs.length === 0) {
      console.log('No jobs found. Try `gogetajob scan <owner/repo>` to add some.');
      return;
    }

    console.log(`\n  Jobs (${jobs.length} results)\n`);
    console.log('  ' + padRight('ID', 6) + padRight('Repo', 30) + padRight('Type', 10) + padRight('Difficulty', 12) + 'Title');
    console.log('  ' + '-'.repeat(100));

    for (const job of jobs as any[]) {
      const ref = `${job.owner}/${job.repo}#${job.issue_number}`;
      console.log(
        '  ' +
        padRight(String(job.id), 6) +
        padRight(ref, 30) +
        padRight(job.type, 10) +
        padRight(job.difficulty, 12) +
        truncate(job.title, 50)
      );
    }
    console.log();
  });

// --- info ---
program
  .command('info <repo>')
  .description('Show company profile for a repo (owner/repo)')
  .action(async (repo: string) => {
    try {
      const company = companyService.getCompanyByOwnerRepo(
        ...repo.split('/') as [string, string]
      );

      if (!company) {
        console.log(`Company not found. Run \`gogetajob scan ${repo}\` first.`);
        return;
      }

      console.log(`\n  Company Profile: ${company.name}\n`);
      console.log(`  URL:              ${company.repo_url}`);
      console.log(`  Language:         ${company.language || 'N/A'}`);
      console.log(`  Stars:            ${company.stars.toLocaleString()}`);
      console.log(`  Forks:            ${company.forks.toLocaleString()}`);
      console.log(`  Open Issues:      ${company.open_issues_count}`);
      console.log(`  PR Merge Rate:    ${company.pr_merge_rate !== null ? company.pr_merge_rate + '%' : 'Not scanned'}`);
      console.log(`  Avg Response:     ${company.avg_response_time_hours !== null ? company.avg_response_time_hours + 'h' : 'Not scanned'}`);
      console.log(`  Contributing:     ${company.contribution_guide || 'None found'}`);
      console.log(`  Last Scanned:     ${company.last_scanned_at || 'Never'}`);
      console.log(`  Description:      ${company.description || 'N/A'}`);
      console.log();
    } catch (err: any) {
      console.error(`Error: ${err.message}`);
      process.exit(1);
    }
  });

// --- take ---
program
  .command('take <ref>')
  .description('Take a job (format: owner/repo#issue_number)')
  .action((ref: string) => {
    try {
      const parsed = parseRef(ref);
      const log = jobService.takeJob(parsed.owner, parsed.repo, parsed.issue);
      console.log(`\n  Taken! Work log #${log.id} created.`);
      console.log(`  Job: ${ref}`);
      console.log(`  Status: taken`);
      console.log(`  Good luck!\n`);
    } catch (err: any) {
      console.error(`Error: ${err.message}`);
      process.exit(1);
    }
  });

// --- done ---
program
  .command('done <ref>')
  .description('Mark a job as completed')
  .option('--pr <number>', 'PR number')
  .option('--tokens <count>', 'tokens consumed')
  .option('--notes <text>', 'completion notes')
  .action((ref: string, opts) => {
    try {
      const parsed = parseRef(ref);
      const log = jobService.completeJob(parsed.owner, parsed.repo, parsed.issue, {
        pr: opts.pr ? parseInt(opts.pr) : undefined,
        tokens: opts.tokens ? parseInt(opts.tokens) : undefined,
        notes: opts.notes,
      });
      console.log(`\n  Done! Work log #${log.id} completed.`);
      console.log(`  Job: ${ref}`);
      if (log.pr_url) console.log(`  PR: ${log.pr_url}`);
      if (log.tokens_used) console.log(`  Tokens: ${log.tokens_used}`);
      console.log();
    } catch (err: any) {
      console.error(`Error: ${err.message}`);
      process.exit(1);
    }
  });

// --- drop ---
program
  .command('drop <ref>')
  .description('Drop a taken job')
  .action((ref: string) => {
    try {
      const parsed = parseRef(ref);
      const log = jobService.dropJob(parsed.owner, parsed.repo, parsed.issue);
      console.log(`\n  Dropped work log #${log.id}.`);
      console.log(`  Job ${ref} is now open again.\n`);
    } catch (err: any) {
      console.error(`Error: ${err.message}`);
      process.exit(1);
    }
  });

// --- history ---
program
  .command('history')
  .description('View work history')
  .option('--repo <owner/repo>', 'filter by repo')
  .option('--status <status>', 'filter by status: taken, done, dropped')
  .action((opts) => {
    const logs = jobService.getHistory({
      repo: opts.repo,
      status: opts.status,
    });

    if (logs.length === 0) {
      console.log('No work history yet.');
      return;
    }

    console.log(`\n  Work History (${logs.length} entries)\n`);
    console.log('  ' + padRight('ID', 6) + padRight('Status', 10) + padRight('Repo', 25) + padRight('Issue', 8) + padRight('Taken', 20) + 'Title');
    console.log('  ' + '-'.repeat(100));

    for (const log of logs) {
      const ref = `${log.owner}/${log.repo}`;
      console.log(
        '  ' +
        padRight(String(log.id), 6) +
        padRight(log.status, 10) +
        padRight(ref, 25) +
        padRight('#' + log.issue_number, 8) +
        padRight(formatDate(log.taken_at), 20) +
        truncate(log.title, 40)
      );
    }
    console.log();
  });

// --- scan ---
program
  .command('scan <repo>')
  .description('Scan a repo for open issues and add them as jobs')
  .option('--refresh', 'force refresh existing jobs')
  .action(async (repo: string, opts) => {
    try {
      console.log(`\n  Scanning ${repo}...`);

      const company = await companyService.scanCompany(repo);
      console.log(`  Company: ${company.name} (${company.stars} stars, merge rate: ${company.pr_merge_rate ?? '?'}%)`);

      const count = await jobService.scanIssues(company, opts.refresh);
      console.log(`  Found ${count} issues.`);
      console.log(`  Done!\n`);
    } catch (err: any) {
      console.error(`Error: ${err.message}`);
      process.exit(1);
    }
  });

// --- companies ---
program
  .command('companies')
  .description('List known companies')
  .option('--sort <field>', 'sort by: stars, merge-rate, activity', 'stars')
  .action((opts) => {
    const companies = companyService.getAllCompanies(opts.sort);

    if (companies.length === 0) {
      console.log('No companies yet. Try `gogetajob scan <owner/repo>` to add one.');
      return;
    }

    console.log(`\n  Companies (${companies.length})\n`);
    console.log('  ' + padRight('Name', 30) + padRight('Stars', 10) + padRight('Merge%', 10) + padRight('Resp(h)', 10) + padRight('Issues', 10) + 'Language');
    console.log('  ' + '-'.repeat(90));

    for (const c of companies) {
      console.log(
        '  ' +
        padRight(c.name, 30) +
        padRight(String(c.stars), 10) +
        padRight(c.pr_merge_rate !== null ? c.pr_merge_rate + '%' : '-', 10) +
        padRight(c.avg_response_time_hours !== null ? String(c.avg_response_time_hours) : '-', 10) +
        padRight(String(c.open_issues_count), 10) +
        (c.language || '-')
      );
    }
    console.log();
  });

// --- server (keep legacy server command) ---
program
  .command('server')
  .description('Start the web server')
  .action(() => {
    require('./server');
  });

program.parse();

// === Helpers ===

function parseRef(ref: string): { owner: string; repo: string; issue: number } {
  const match = ref.match(/^([^\/]+)\/([^#]+)#(\d+)$/);
  if (!match) {
    throw new Error(`Invalid ref format: "${ref}". Expected: owner/repo#issue_number`);
  }
  return { owner: match[1], repo: match[2], issue: parseInt(match[3]) };
}

function padRight(s: string, len: number): string {
  return s.length >= len ? s.substring(0, len) : s + ' '.repeat(len - s.length);
}

function truncate(s: string, len: number): string {
  if (s.length <= len) return s;
  return s.substring(0, len - 3) + '...';
}

function formatDate(d: string | null): string {
  if (!d) return '-';
  return d.replace('T', ' ').substring(0, 16);
}
